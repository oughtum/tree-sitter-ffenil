ifThenElse     = if isOdd 1 then "odd" else "even";
andOr          = true and (false or true);
letIn          = let x = 4; in 4;
doExpr         = do print ":3";
enum Option    = Some str | None;
inherited =
  let
    a = ":D";
    b = ":o";
  in
    { inherit a b };
option = Option::None;
matchExpr = match option;
  Some { a = false } => true,
  None => false;
a              = 1;
record         = { a = 2 };
withExpr       = with record; a;
scopedWithExpr = with scoped record; a;

called = a.b.c 4;

pub public = ":D";
private    = ":c";

return { hostName = "gallifrey" };

