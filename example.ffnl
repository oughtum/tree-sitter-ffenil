import modules::lib;
merge modules::conf;
import modules::libAndConf;

import std;
import std::io;
merge root::myModule;

str             = "foo bar";
interpolatedStr = "${str} baz";
rawString       = r#"foo bar"#;
decimalInt      = 42;
binaryInt       = 0b0101;
octalInt        = 0o27;
hexInt          = 0x9F0ACF;
float           = 3.14;
bool            = false;
unit            = ();
tuple           = (1.0, 2.0, false);
array           = [ 1, 2, 3, 4, 5 ];
record          = { name = "Toby Larone", age = 37 };
closure         = |a : int| |b : int| a + b;

mutated = let
  mut x = 4;
  y = 5;
  x <- y;
in
  x; -- returns 5

updatedRecord = let
  mut record             = { key = "value" };
  record.key2           <- 4;
  record."stringKey :3" <- true;
  record                <- { freshKey = "freshValue" };
in
  record; 

type TypeAlias   = [(float, int)];

type UnitType    = ();
type AnyType     = any;
type StrType     = str;
type IntType     = int;
type FloatType   = float;
type BoolType    = bool;
type TupleType   = (int, bool);
type ArrayType   = [str];
type RecordType  = { key : str, optionalKey? : float, "stringKey" : bool, .. };
type ClosureType = int -> int -> int;

inferredType       = ":3";
explicitType : int = 7;

{-
  block comment
-}

